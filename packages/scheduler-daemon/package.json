{
  "name": "pi-scheduler-daemon",
  "version": "0.1.0",
  "description": "Standalone daemon for pi-scheduler automations",
  "type": "module",
  "bin": {
    "pi-scheduler-daemon": "./dist/daemon.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "pi-scheduler-core": "^0.1.0"
  },
  "keywords": [
    "scheduler",
    "daemon",
    "agent",
    "automation"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.7.3"
  }
}
